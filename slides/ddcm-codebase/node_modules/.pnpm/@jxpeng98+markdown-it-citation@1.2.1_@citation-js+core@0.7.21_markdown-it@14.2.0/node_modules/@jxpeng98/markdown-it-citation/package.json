{
    "name": "@jxpeng98/markdown-it-citation",
    "version": "1.2.1",
    "description": "A markdown-it plugin for citations and bibliography",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "files": [
        "dist",
        "README.md",
        "styles.css"
    ],
    "publishConfig": {
        "access": "public"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "development": "./src/index.ts",
            "default": "./dist/index.js"
        },
        "./styles.css": "./styles.css"
    },
    "scripts": {
        "build": "tsc",
        "dev": "tsc --watch",
        "test": "bun test/run.ts"
    },
    "keywords": [
        "markdown-it",
        "citation",
        "bibliography",
        "bibtex",
        "vitepress"
    ],
    "author": "Jiaxin Peng",
    "license": "MIT",
    "dependencies": {
        "@citation-js/plugin-csl": "^0.7.21",
        "citation-js": "^0.7.14",
        "js-yaml": "^4.1.1"
    },
    "peerDependencies": {
        "markdown-it": "^14.1.0"
    },
    "devDependencies": {
        "@types/js-yaml": "^4.0.9",
        "@types/markdown-it": "^14.1.2",
        "@types/node": "^22.10.1",
        "typescript": "^5.7.2"
    }
}
